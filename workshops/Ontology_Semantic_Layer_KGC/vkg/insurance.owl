@prefix : <http://example.org/insurance#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Claim a owl:Class .
:Policy a owl:Class .
:PolicyCoverage a owl:Class .
:ClaimEvent a owl:Class .
:Customer a owl:Class .

:claimId a owl:DatatypeProperty ;
    rdfs:domain :Claim ;
    rdfs:range xsd:string .

:claimAmount a owl:DatatypeProperty ;
    rdfs:domain :Claim ;
    rdfs:range xsd:decimal .

:incidentDate a owl:DatatypeProperty ;
    rdfs:domain :Claim ;
    rdfs:range xsd:dateTime .

:forPolicy a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain :Claim ;
    rdfs:range :Policy .

:hasEvent a owl:ObjectProperty ;
    rdfs:domain :Claim ;
    rdfs:range :ClaimEvent .

:eventType a owl:DatatypeProperty ;
    rdfs:domain :ClaimEvent ;
    rdfs:range xsd:string .

:eventTimestamp a owl:DatatypeProperty ;
    rdfs:domain :ClaimEvent ;
    rdfs:range xsd:dateTime .

:eventAmount a owl:DatatypeProperty ;
    rdfs:domain :ClaimEvent ;
    rdfs:range xsd:decimal .

:policyId a owl:DatatypeProperty ;
    rdfs:domain :Policy ;
    rdfs:range xsd:string .

:policyType a owl:DatatypeProperty ;
    rdfs:domain :Policy ;
    rdfs:range xsd:string .

:heldBy a owl:ObjectProperty ;
    rdfs:domain :Policy ;
    rdfs:range :Customer .

:hasCoverage a owl:ObjectProperty ;
    rdfs:domain :Policy ;
    rdfs:range :PolicyCoverage .

:coverageAmount a owl:DatatypeProperty ;
    rdfs:domain :PolicyCoverage ;
    rdfs:range xsd:decimal .

:deductible a owl:DatatypeProperty ;
    rdfs:domain :PolicyCoverage ;
    rdfs:range xsd:decimal .

:premium a owl:DatatypeProperty ;
    rdfs:domain :PolicyCoverage ;
    rdfs:range xsd:decimal .

:validFrom a owl:DatatypeProperty ;
    rdfs:domain :PolicyCoverage ;
    rdfs:range xsd:dateTime .

:validTo a owl:DatatypeProperty ;
    rdfs:domain :PolicyCoverage ;
    rdfs:range xsd:dateTime .

:isCurrent a owl:DatatypeProperty ;
    rdfs:domain :PolicyCoverage ;
    rdfs:range xsd:boolean .

:customerId a owl:DatatypeProperty ;
    rdfs:domain :Customer ;
    rdfs:range xsd:string .

:customerName a owl:DatatypeProperty ;
    rdfs:domain :Customer ;
    rdfs:range xsd:string .

:netPayable a owl:DatatypeProperty ;
    rdfs:domain :Claim ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Derived property: the amount the insurer owes after applying the deductible. Computed via SPARQL CONSTRUCT, not stored in source data." .
