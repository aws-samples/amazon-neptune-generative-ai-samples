<mxfile>
  <diagram name="Workshop Architecture" id="arch">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- VPC -->
        <mxCell id="vpc" value="VPC (10.0.0.0/16)" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=12;fontStyle=1;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_vpc;strokeColor=#248814;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;spacingTop=5;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="50" y="30" width="700" height="420" as="geometry"/>
        </mxCell>

        <!-- Private Subnets -->
        <mxCell id="private" value="Private Subnets" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=11;fontStyle=1;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_security_group;strokeColor=#147EBA;fillColor=#E6F2F8;verticalAlign=top;align=left;spacingLeft=30;spacingTop=5;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="70" y="70" width="350" height="360" as="geometry"/>
        </mxCell>

        <!-- Public Subnets -->
        <mxCell id="public" value="Public Subnets" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=11;fontStyle=1;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_security_group;strokeColor=#147EBA;fillColor=#E6F2F8;verticalAlign=top;align=left;spacingLeft=30;spacingTop=5;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="440" y="70" width="290" height="360" as="geometry"/>
        </mxCell>

        <!-- Neptune -->
        <mxCell id="neptune" value="Amazon Neptune&lt;br&gt;&lt;font style=&quot;font-size:10px;font-weight:normal&quot;&gt;db.r8g.xlarge&lt;br&gt;SPARQL :8182&lt;br&gt;IAM Auth&lt;/font&gt;" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#C925D1;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.neptune;" vertex="1" parent="1">
          <mxGeometry x="170" y="100" width="60" height="60" as="geometry"/>
        </mxCell>

        <!-- ECS / Ontop -->
        <mxCell id="alb" value="Internal ALB" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_load_balancing;" vertex="1" parent="1">
          <mxGeometry x="100" y="220" width="48" height="48" as="geometry"/>
        </mxCell>

        <mxCell id="ecs" value="ECS Fargate&lt;br&gt;&lt;font style=&quot;font-size:10px;font-weight:normal&quot;&gt;Ontop VKG&lt;br&gt;SPARQL → SQL&lt;/font&gt;" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ecs;" vertex="1" parent="1">
          <mxGeometry x="240" y="220" width="60" height="60" as="geometry"/>
        </mxCell>

        <!-- ALB to ECS arrow -->
        <mxCell id="alb2ecs" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="alb" target="ecs" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- SageMaker Notebook -->
        <mxCell id="notebook" value="SageMaker Notebook&lt;br&gt;&lt;font style=&quot;font-size:10px;font-weight:normal&quot;&gt;ml.m7i.2xlarge&lt;br&gt;JupyterLab&lt;/font&gt;" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#A166FF;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.sagemaker;" vertex="1" parent="1">
          <mxGeometry x="170" y="340" width="60" height="60" as="geometry"/>
        </mxCell>

        <!-- NAT Gateway in public subnet -->
        <mxCell id="nat" value="NAT Gateway" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.nat_gateway;" vertex="1" parent="1">
          <mxGeometry x="550" y="150" width="48" height="48" as="geometry"/>
        </mxCell>

        <!-- Internet Gateway -->
        <mxCell id="igw" value="Internet&lt;br&gt;Gateway" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.internet_gateway;" vertex="1" parent="1">
          <mxGeometry x="550" y="300" width="48" height="48" as="geometry"/>
        </mxCell>

        <!-- Bedrock (outside VPC) -->
        <mxCell id="bedrock" value="Amazon Bedrock&lt;br&gt;&lt;font style=&quot;font-size:10px;font-weight:normal&quot;&gt;Claude Haiku 4.5&lt;br&gt;NL→SPARQL | Denial Explain&lt;br&gt;Info Extraction | Guardrails&lt;/font&gt;" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#01A88D;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.bedrock;" vertex="1" parent="1">
          <mxGeometry x="870" y="180" width="60" height="60" as="geometry"/>
        </mxCell>

        <!-- Participant -->
        <mxCell id="user" value="Workshop&lt;br&gt;Participant" style="outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.user;" vertex="1" parent="1">
          <mxGeometry x="870" y="340" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- Notebook to Neptune -->
        <mxCell id="nb2nep" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C925D1;strokeWidth=2;" edge="1" source="notebook" target="neptune" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="nb2nep_label" value="SPARQL" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;" vertex="1" connectable="0" parent="nb2nep">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>

        <!-- Notebook to ALB/Ontop -->
        <mxCell id="nb2alb" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#ED7100;strokeWidth=2;" edge="1" source="notebook" target="alb" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="nb2alb_label" value="SPARQL" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;" vertex="1" connectable="0" parent="nb2alb">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>

        <!-- Notebook to Bedrock (via NAT/IGW) -->
        <mxCell id="nb2bedrock" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#01A88D;strokeWidth=2;" edge="1" source="notebook" target="bedrock" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="400" y="370"/>
              <mxPoint x="800" y="370"/>
              <mxPoint x="800" y="210"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="nb2bedrock_label" value="Bedrock API" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;" vertex="1" connectable="0" parent="nb2bedrock">
          <mxGeometry x="0.3" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>

        <!-- User to Notebook (via SageMaker console) -->
        <mxCell id="user2nb" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#232F3E;strokeWidth=2;dashed=1;" edge="1" source="user" target="notebook" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="800" y="420"/>
              <mxPoint x="400" y="420"/>
              <mxPoint x="400" y="370"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="user2nb_label" value="SageMaker Console&lt;br&gt;(presigned URL)" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;" vertex="1" connectable="0" parent="user2nb">
          <mxGeometry x="0.3" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
